{
  "name": "esteira-dev-gp",
  "displayName": "Esteira Growth",
  "description": "Gerencie a esteira de desenvolvimento com 4 etapas: Produto, Desenvolvimento, QA e Deploy",
  "version": "0.2.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "esteira.openPanel",
        "title": "Esteira: Abrir Painel"
      },
      {
        "command": "esteira.jiraLogin",
        "title": "Esteira: Conectar ao Jira"
      },
      {
        "command": "esteira.jiraLogout",
        "title": "Esteira: Desconectar do Jira"
      }
    ],
    "configuration": {
      "title": "Esteira Growth",
      "properties": {
        "jira.trackedProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Chaves dos projetos Jira a exibir na sidebar (ex: MARTECH, CRM). Se vazio, mostra apenas issues atribuídas a você."
        },
        "cportGitFlow.projectCode": {
          "type": "string",
          "default": "cport",
          "description": "Codigo do projeto usado na nomenclatura de branches (ex: feat/cport-1234). Altere para o prefixo do seu projeto."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "esteira-explorer",
          "title": "Esteira Growth",
          "icon": "media/icons/grupo-primo-gp_smooth_ring_monochrome.svg"
        }
      ]
    },
    "views": {
      "esteira-explorer": [
        {
          "type": "webview",
          "id": "esteira.sidebarView",
          "name": "Esteira Growth"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}

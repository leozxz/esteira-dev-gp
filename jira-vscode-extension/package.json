{
  "name": "jira-connector",
  "displayName": "Jira Connector",
  "description": "Crie e visualize issues do Jira direto no VS Code",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jira.login",
        "title": "Jira: Login"
      },
      {
        "command": "jira.logout",
        "title": "Jira: Logout"
      },
      {
        "command": "jira.createIssue",
        "title": "Jira: Criar Issue"
      },
      {
        "command": "jira.refreshIssues",
        "title": "Jira: Atualizar Issues",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jira-explorer",
          "title": "Jira",
          "icon": "media/icons/jira.svg"
        }
      ]
    },
    "views": {
      "jira-explorer": [
        {
          "id": "jiraIssues",
          "name": "Issues",
          "when": "jira.isLoggedIn"
        },
        {
          "id": "jiraWelcome",
          "name": "Jira",
          "when": "!jira.isLoggedIn"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "jiraWelcome",
        "contents": "Conecte-se ao Jira para ver suas issues.\n[Login no Jira](command:jira.login)"
      }
    ],
    "configuration": {
      "title": "Jira Connector",
      "properties": {
        "jira.trackedProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Chaves dos projetos Jira a exibir na sidebar (ex: MARTECH, CRM). Se vazio, mostra apenas issues atribuídas a você."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "jira.refreshIssues",
          "when": "view == jiraIssues",
          "group": "navigation"
        },
        {
          "command": "jira.createIssue",
          "when": "view == jiraIssues",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
